# -------------------------------
# 🐍 Base Image
# -------------------------------
FROM python:3.12-slim

# -------------------------------
# 📁 Set Working Directory
# -------------------------------
WORKDIR /app

# -------------------------------
# 📦 Copy Files
# -------------------------------
COPY . .

# -------------------------------
# 📦 Install Dependencies
# -------------------------------
RUN pip install --no-cache-dir -r requirements.txt

# -------------------------------
# 🌱 Environment Variables
# -------------------------------
ENV PYTHONUNBUFFERED=1

# -------------------------------
# 🚀 Expose Port
# -------------------------------
EXPOSE 8000

# -------------------------------
# ▶️ Run FastAPI
# -------------------------------
CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]